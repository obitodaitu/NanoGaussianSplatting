// Purpose: GPU-side reset of VisibleSplatCountBuffer.
// Replaces the CPU LockBuffer stall that was flushing the GPU pipeline every frame.
// Dispatched as (1,1,1) with 1 thread.

#include "/Engine/Public/Platform.ush"

RWStructuredBuffer<uint> VisibleSplatCount;

[numthreads(1, 1, 1)]
void ResetCS(uint3 DispatchThreadId : SV_DispatchThreadID)
{
	VisibleSplatCount[0] = 0;
}
